{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "apk": {
      "extends": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "environment": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "NEXT_PUBLIC_SITE_URL": "https://www.taplite.store",
        "NEXT_PUBLIC_SUPABASE_URL": "https://qqplffyjlpdhqwegbtea.supabase.co"
      }
    },
    "production": {
      "environment": "production",
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production-apk": {
      "extends": "production",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
