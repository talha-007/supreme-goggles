{
  "expo": {
    "name": "Taplite",
    "slug": "pos-mobile",
    "scheme": "pos-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-logo.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/app-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.supremegoggles.posmobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.supremegoggles.posmobile"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/app-logo.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "siteUrl": "http://localhost:3000",
      "privacyPolicyUrl": "",
      "router": {},
      "eas": {
        "projectId": "3a8e0b3a-cbfa-4ab6-9957-865d3ffa0736"
      }
    },
    "owner": "kakarot_7"
  }
}
