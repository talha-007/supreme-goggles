{
  "name": "pos-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "node ./scripts/ensure-assets.cjs && node ./scripts/patch-expo-keep-awake.cjs",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:android": "expo prebuild --platform android --clean",
    "build:apk:debug": "cd android && gradlew.bat assembleDebug",
    "build:apk:debug:clean": "cd android && gradlew.bat clean assembleDebug",
    "build:apk:release": "cd android && gradlew.bat assembleRelease -PreactNativeArchitectures=arm64-v8a",
    "build:apk:release:clean": "cd android && gradlew.bat clean assembleRelease -PreactNativeArchitectures=arm64-v8a",
    "build:apk:release:all-arm": "cd android && gradlew.bat assembleRelease -PreactNativeArchitectures=armeabi-v7a,arm64-v8a",
    "eas:login": "eas login",
    "eas:whoami": "eas whoami",
    "eas:init": "eas init",
    "eas:build:android:apk": "eas build --platform android --profile apk",
    "eas:build:android:apk:preview": "eas build --platform android --profile preview",
    "eas:build:android:aab": "eas build --platform android --profile production",
    "eas:build:android:apk:production": "eas build --platform android --profile production-apk",
    "eas:build:ios": "eas build --platform ios --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.49.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "eas-cli": "^16.28.0",
    "@babel/core": "^7.26.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "dotenv": "^16.4.7",
    "typescript": "~5.9.2"
  },
  "private": true
}
